<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black">

    <!-- Основное видео собеседника -->
    <FrameLayout
            android:id="@+id/remote_video_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <io.livekit.android.renderer.SurfaceViewRenderer
                android:id="@+id/remote_video_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="visible" />

        <FrameLayout
                android:id="@+id/remote_muted_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_gradient"
                android:visibility="gone"
                android:clickable="false">

            <ImageView
                    android:id="@+id/remote_avatar_view"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="12dp"
                    android:src="@drawable/ic_avatar_default"
                    app:tint="@android:color/white" />

            <TextView
                    android:id="@+id/remote_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="60dp"
                    android:text="Собеседник"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="2" />

            <!-- Иконка выключенной камеры -->
            <ImageView
                    android:layout_width="40dp"
                    android:layout_height="80dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="16dp"
                    android:src="@drawable/ic_camera_off"
                    app:tint="@android:color/white" />
        </FrameLayout>

        <!-- Индикатор подключения -->
        <TextView
                android:id="@+id/connection_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@drawable/bg_rounded_corners"
                android:padding="8dp"
                android:text="Подключение..."
                android:textColor="@android:color/white"
                android:visibility="visible" />

    </FrameLayout>

    <!-- Превью собственной камеры (маленький вид) -->
    <FrameLayout
            android:id="@+id/local_video_container"
            android:layout_width="160dp"
            android:layout_height="240dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_margin="16dp"
            android:elevation="8dp">

        <io.livekit.android.renderer.SurfaceViewRenderer
                android:id="@+id/local_video_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible" />

        <FrameLayout
                android:id="@+id/local_muted_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_local_muted"
                android:visibility="gone"
                android:clickable="false">

            <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera_off"
                    app:tint="@android:color/white" />

            <!-- Индикатор, что это ваше видео -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_rounded_corners"
                    android:padding="4dp"
                    android:text="Вы"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

        </FrameLayout>

        <!--        <ImageView-->
        <!--                android:id="@+id/local_avatar_view"-->
        <!--                android:layout_width="80dp"-->
        <!--                android:layout_height="80dp"-->
        <!--                android:layout_gravity="center"-->
        <!--                android:background="@drawable/bg_avatar_gradient"-->
        <!--                android:src="@drawable/ic_avatar_default"-->
        <!--                android:visibility="gone" />-->

        <!-- CameraX Preview (резервный, скрыт по умолчанию) -->
        <!--        <androidx.camera.view.PreviewView-->
        <!--                android:id="@+id/camerax_preview_view"-->
        <!--                android:layout_width="match_parent"-->
        <!--                android:layout_height="match_parent"-->
        <!--                android:visibility="gone" />-->


        <!-- Индикатор отключенной камеры -->
                <ImageView
                        android:id="@+id/camera_off_indicator"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera_off"
                        android:visibility="gone" />
    </FrameLayout>

    <!-- Панель управления -->
    <LinearLayout
            android:id="@+id/control_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_margin="24dp"
            android:gravity="center"
            android:orientation="horizontal">

        <!-- Кнопка завершения звонка -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/end_call_button"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginEnd="32dp"
                android:src="@drawable/ic_call_end"
                app:backgroundTint="@color/red"
                app:tint="@android:color/white" />

        <!-- Кнопка микрофона -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/microphone_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="24dp"
                android:src="@drawable/ic_mic_on"
                app:backgroundTint="@color/purple_500"
                app:tint="@android:color/white" />

        <!-- Кнопка камеры -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/camera_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_videocam_on"
                app:backgroundTint="@color/purple_500"
                app:tint="@android:color/white" />
    </LinearLayout>

</RelativeLayout>